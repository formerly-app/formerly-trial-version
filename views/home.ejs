<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Motion - Make Animated Videos with Text, Shapes, and Media</title>
  <meta name="description" content="Create motion design videos on a fast, minimalist web-based editor. No downloads, no complexity—just create.">
  <link rel="icon" type="image/x-icon" href="/favicon.ico">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&family=Work+Sans:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/global.css">
  <link rel="stylesheet" href="/css/components.css">
  <link rel="stylesheet" href="/css/landing.css">
</head>
<body>
  <!-- Navbar -->
  <header class="navbar">
    <nav class="container navbar-inner">
      <a href="/" class="logo">
        <div class="logo-icon">M</div>
        <span class="logo-text">Motion</span>
      </a>

      <!-- Desktop Navigation -->
      <div class="nav-links">
        <a href="#how-it-works" class="nav-link">How It Works</a>
      </div>

      <div class="nav-buttons">
        <a href="/login" class="btn-secondary">Log in</a>
        <a href="/signup" class="btn-primary">Get Started</a>
      </div>

      <!-- Mobile Menu Button -->
      <button class="mobile-menu-btn" id="mobileMenuBtn" aria-label="Toggle menu">
        <svg class="menu-icon" id="menuIcon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
        <svg class="close-icon hidden" id="closeIcon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </nav>

    <!-- Mobile Menu -->
    <div class="mobile-menu hidden" id="mobileMenu">
      <div class="container mobile-menu-inner">
        <a href="#how-it-works" class="mobile-nav-link">How It Works</a>
          <div class="mobile-menu-buttons">
            <a href="/login" class="btn-secondary">Log in</a>
            <a href="/signup" class="btn-primary">Get Started</a>
          </div>
      </div>
    </div>
  </header>

  <main>
    <!-- Hero Section -->
    <section class="hero">
      <!-- Background decoration -->
      <div class="hero-bg">
        <div class="hero-blob hero-blob-1"></div>
        <div class="hero-blob hero-blob-2"></div>
      </div>

      <div class="container">
        <div class="hero-content">
          <!-- Badge -->
          <div class="badge animate-fade-up">
            <span class="badge-dot"></span>
            <span class="badge-text">Now in public beta</span>
          </div>

          <!-- Main Headline -->
          <h1 class="hero-title animate-fade-up-delay-1">
            Make animated videos using
            <span class="text-primary">Text</span>,
            <span class="text-primary">Shapes</span>, and
            <span class="text-primary">Media</span>
          </h1>

          <!-- Subheadline -->
          <p class="hero-subtitle animate-fade-up-delay-2">
            Create motion design videos on a fast, minimalist web-based editor.
            No downloads. No timelines. Just frames and smooth motion.
          </p>

          <!-- CTA Buttons -->
          <div class="hero-buttons animate-fade-up-delay-3">
            <a href="/signup" class="btn-primary">
              Get Started Free
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="5" y1="12" x2="19" y2="12"></line>
                <polyline points="12 5 19 12 12 19"></polyline>
              </svg>
            </a>
            <button class="btn-secondary">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                <polygon points="5 3 19 12 5 21 5 3"></polygon>
              </svg>
              Watch Demo
            </button>
          </div>
        </div>

        <!-- Hero Illustration -->
        <div class="hero-illustration animate-fade-up-delay-3">
          <div class="editor-mockup">
            <div class="editor-gradient-overlay"></div>
            
            <!-- Editor Header -->
            <div class="editor-header">
              <div class="editor-dots">
                <div class="dot dot-red"></div>
                <div class="dot dot-yellow"></div>
                <div class="dot dot-green"></div>
              </div>
              <div class="editor-url">
                <div class="url-bar">motion.app/editor</div>
              </div>
            </div>

            <!-- Editor Content -->
            <div class="editor-content">
              <div class="canvas">
                <!-- Animated elements -->
                <div class="canvas-element text-element animate-float">Hello World</div>
                <div class="canvas-element circle-element animate-float" style="animation-delay: 1s;"></div>
                <div class="canvas-element square-element animate-float" style="animation-delay: 2s;"></div>
                <div class="canvas-element media-element animate-float" style="animation-delay: 0.5s;">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                    <polygon points="5 3 19 12 5 21 5 3"></polygon>
                  </svg>
                </div>
              </div>

              <!-- Timeline -->
              <div class="timeline">
                <div class="timeline-header">
                  <div class="timeline-label">Timeline</div>
                  <div class="timeline-divider"></div>
                  <div class="timeline-time">00:00 / 00:10</div>
                </div>
                <div class="timeline-tracks">
                  <div class="track">
                    <div class="track-label">Text</div>
                    <div class="track-bar track-bar-text"></div>
                  </div>
                  <div class="track">
                    <div class="track-label">Shape</div>
                    <div class="track-bar track-bar-shape"></div>
                  </div>
                  <div class="track">
                    <div class="track-label">Media</div>
                    <div class="track-bar track-bar-media"></div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- How It Works Section -->
    <section id="how-it-works" class="how-it-works">
      <div class="container">
        <div class="section-header">
          <h2 class="section-title">How It Works</h2>
          <p class="section-subtitle">Create stunning animations in three simple steps</p>
        </div>

        <div class="steps-grid">
          <div class="step-card">
            <div class="step-number">1</div>
            <div class="step-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                <line x1="9" y1="3" x2="9" y2="21"></line>
              </svg>
            </div>
            <h3 class="step-title">Create Your Canvas</h3>
            <p class="step-description">
              Start with a blank canvas and add text, shapes, or media elements. Drag and drop to position everything exactly where you want it.
            </p>
          </div>

          <div class="step-card">
            <div class="step-number">2</div>
            <div class="step-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline>
              </svg>
            </div>
            <h3 class="step-title">Add Frames & Animate</h3>
            <p class="step-description">
              Create multiple frames and define how elements move between them.
            </p>
          </div>

          <div class="step-card">
            <div class="step-number">3</div>
            <div class="step-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polygon points="5 3 19 12 5 21 5 3"></polygon>
              </svg>
            </div>
            <h3 class="step-title">Export & Share</h3>
            <p class="step-description">
              Export your animation as a high-quality video file. Share it directly or download for use in your projects.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Pricing Section -->
    <section id="pricing" class="pricing">
      <div class="container">
        <div class="section-header">
          <div class="section-kicker">💳 Pricing</div>
          <h2 class="section-title">Simple plans. Clear limits.</h2>
          <p class="section-subtitle">Pick the plan that matches how you create.</p>
        </div>

        <div class="pricing-grid">
          <div class="pricing-card">
            <div class="pricing-meta">
              <div class="pricing-plan">Free</div>
              <div class="pricing-price">$0</div>
              <p class="pricing-desc">Perfect for trying frame-based motion</p>
            </div>
            <ul class="pricing-list">
              <li class="pricing-item check">Create projects using Text, Shapes, and Media</li>
              <li class="pricing-item cross">Frame size is fixed after project creation</li>
              <li class="pricing-item check">Downloads in standard quality</li>
              <li class="pricing-item cross">Access to basic elements only</li>
            </ul>
            <a href="/signup" class="btn-primary pricing-cta">Get Started Free</a>
          </div>

          <div class="pricing-card premium">
            <div class="pricing-badge">Recommended</div>
            <div class="pricing-meta">
              <div class="pricing-plan">Premium</div>
              <div class="pricing-price">$19</div>
              <p class="pricing-desc">Full creative freedom</p>
            </div>
            <ul class="pricing-list">
              <li class="pricing-item check">Change frame size anytime</li>
              <li class="pricing-item check">Downloads in high quality</li>
              <li class="pricing-item check">Access to all elements (100%)</li>
            </ul>
            <a href="/signup" class="btn-primary pricing-cta">Upgrade to Premium</a>
            <p class="pricing-micro">Best for serious creators</p>
          </div>
        </div>
      </div>
    </section>

    <!-- What You Can Create Section -->
    <section id="what-you-can-create" class="what-you-can-create">
      <div class="container">
        <div class="section-header">
          <h2 class="section-title">What you can create</h2>
          <p class="section-subtitle">Explore the possibilities with Motion</p>
        </div>

        <div class="create-grid">
          <div class="create-card">
            <div class="create-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect>
                <line x1="8" y1="21" x2="16" y2="21"></line>
                <line x1="12" y1="17" x2="12" y2="21"></line>
              </svg>
            </div>
            <h3 class="create-title">Product demos</h3>
          </div>

          <div class="create-card">
            <div class="create-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="2" y="4" width="20" height="16" rx="2"></rect>
                <path d="M6 8h12M6 12h12M6 16h8"></path>
              </svg>
            </div>
            <h3 class="create-title">Landing page animations</h3>
          </div>

          <div class="create-card">
            <div class="create-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path>
                <polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline>
                <line x1="12" y1="22.08" x2="12" y2="12"></line>
              </svg>
            </div>
            <h3 class="create-title">Social media intros</h3>
          </div>

          <div class="create-card">
            <div class="create-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"></circle>
                <polyline points="12 6 12 12 16 14"></polyline>
              </svg>
            </div>
            <h3 class="create-title">Tutorial videos</h3>
          </div>

          <div class="create-card">
            <div class="create-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                <line x1="9" y1="3" x2="9" y2="21"></line>
              </svg>
            </div>
            <h3 class="create-title">Animated banners</h3>
          </div>

          <div class="create-card">
            <div class="create-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polygon points="5 3 19 12 5 21 5 3"></polygon>
              </svg>
            </div>
            <h3 class="create-title">Promotional content</h3>
          </div>
        </div>
      </div>
    </section>

    <!-- Built for Creators Section -->
    <section id="built-for-creators" class="built-for-creators">
      <div class="container">
        <div class="section-header">
          <h2 class="section-title">Built for creators like you</h2>
          <p class="section-subtitle">Designed with your workflow in mind</p>
        </div>

        <div class="creators-grid">
          <div class="creator-quote">
            <div class="quote-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="3" width="7" height="7"></rect>
                <rect x="14" y="3" width="7" height="7"></rect>
                <rect x="14" y="14" width="7" height="7"></rect>
                <rect x="3" y="14" width="7" height="7"></rect>
              </svg>
            </div>
            <p class="quote-text">Designed for designers who want motion without timelines.</p>
          </div>

          <div class="creator-quote">
            <div class="quote-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M12 2L2 7l10 5 10-5-10-5z"></path>
                <path d="M2 17l10 5 10-5"></path>
                <path d="M2 12l10 5 10-5"></path>
              </svg>
            </div>
            <p class="quote-text">Made for founders creating product videos fast.</p>
          </div>

          <div class="creator-quote">
            <div class="quote-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
              </svg>
            </div>
            <p class="quote-text">Built for marketers who need animations without complexity.</p>
          </div>
        </div>
      </div>
    </section>
  </main>

  <!-- Footer -->
  <footer class="footer">
    <div class="container footer-inner">
      <!-- Logo -->
      <div class="logo">
        <div class="logo-icon">M</div>
