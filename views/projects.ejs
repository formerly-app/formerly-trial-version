<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Projects - Motion</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&family=Work+Sans:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" integrity="sha512-z3gLpd7yknf1YoNbCzqRKc4qyor8gaKU1qmn+CShxbuBusANI9QpRohGBreCFkKxLhei6S9CQXFEbbKuqLg0DA==" crossorigin="anonymous" referrerpolicy="no-referrer" />
  <link rel="stylesheet" href="/css/global.css">
  <link rel="stylesheet" href="/css/components.css">
  <link rel="stylesheet" href="/css/dashboard.css">
</head>
<body class="dashboard">
  <div class="dashboard-layout">
    <!-- Sidebar -->
    <aside class="sidebar">
      <div class="sidebar-header">
        <a href="/" class="logo">
          <div class="logo-icon">M</div>
          <span class="logo-text">Motion</span>
        </a>
      </div>
      <div class="search-bar">
        <i class="fas fa-search"></i>
        <input type="text" placeholder="Search projects...">
      </div>
      
      <!-- user-profile moved to bottom; dropdown menu will be rendered there -->
      
      <nav class="sidebar-nav">
        <a href="/dashboard" class="nav-item <%= activeRoute === 'dashboard' ? 'active' : '' %>">
          <i class="fas fa-home"></i>
          <span>Home</span>
        </a>
        <a href="/projects" class="nav-item <%= activeRoute === 'projects' ? 'active' : '' %>">
          <i class="far fa-folder"></i>
          <span>Projects</span>
        </a>
      </nav>
      
      <!-- User profile at the bottom with a toggle menu for Settings and Logout -->
      <div class="user-profile" id="userProfileBtn" tabindex="0" role="button" aria-expanded="false">
        <div class="user-avatar">
          <%= user.name.charAt(0).toUpperCase() %>
        </div>
        <div class="user-info">
          <div class="user-name"><%= user.name %></div>
        </div>

        <div class="user-menu" id="userMenu" aria-hidden="true">
          <div class="menu-header">
            <div class="user-avatar"><%= user.name.charAt(0).toUpperCase() %></div>
            <div class="user-info">
              <div class="user-name"><%= user.name %></div>
              <div class="user-email"><%= user.email %></div>
            </div>
          </div>
          <a href="/settings"><i class="fas fa-cog"></i><span>Settings</span></a>
          <a href="/logout"><i class="fas fa-sign-out-alt"></i><span>Logout</span></a>
        </div>
      </div>
    </aside>

    <!-- Main Content -->
    <main class="main-content">
      <header class="top-bar">
        <span class="top-bar-title">Projects</span>
        <button class="top-bar-create-btn btn-primary-dash">
          <i class="fas fa-plus"></i>
          <span>New Project</span>
        </button>
      </header>
      
      <div class="projects-grid projects">
        <!-- Project cards will be generated here -->
      </div>
    </main>
  </div>

  <script>
    // Sample project data
    const projects = [
      { name: 'Summer Campaign', image: 'https://picsum.photos/seed/1/300/200' },
      { name: 'Product Demo', image: 'https://picsum.photos/seed/2/300/200' },
      { name: 'Brand Identity', image: 'https://picsum.photos/seed/3/300/200' },
      { name: 'Social Media', image: 'https://picsum.photos/seed/4/300/200' },
      { name: 'Event Promo', image: 'https://picsum.photos/seed/5/300/200' },
      { name: 'Tutorial Series', image: 'https://picsum.photos/seed/6/300/200' },
      { name: 'App Showcase', image: 'https://picsum.photos/seed/7/300/200' },
      { name: 'Explainer Video', image: 'https://picsum.photos/seed/8/300/200' }
    ];

    // Generate project cards
    const projectsGrid = document.querySelector('.projects-grid');
    
    projects.forEach((project, index) => {
      const projectCard = document.createElement('div');
      projectCard.className = 'project-card';
      projectCard.innerHTML = `
        <div class="project-image" style="background-image: url('${project.image}')">
          <div class="project-overlay">
            <button class="btn-primary-dash">Open</button>
          </div>
        </div>
        <div class="project-info">
          <h3>${project.name}</h3>
          <div class="project-meta">
            <span><i class="far fa-clock"></i> 2h ago</span>
            <span><i class="far fa-folder"></i> Work</span>
          </div>
        </div>
      `;
      projectsGrid.appendChild(projectCard);
    });

    // User profile dropdown toggle
    (function() {
      const userBtn = document.getElementById('userProfileBtn');
      const userMenu = document.getElementById('userMenu');

      if (!userBtn || !userMenu) return;

      userBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        e.preventDefault();
        
        if (userMenu.classList.contains('show')) {
          userMenu.classList.remove('show');
          userMenu.setAttribute('aria-hidden', 'true');
          userBtn.setAttribute('aria-expanded', 'false');
        } else {
          userMenu.classList.add('show');
          userMenu.setAttribute('aria-hidden', 'false');
          userBtn.setAttribute('aria-expanded', 'true');
        }
      });

      // Close when clicking outside
      document.addEventListener('click', function(e) {
        if (!userBtn.contains(e.target) && !userMenu.contains(e.target)) {
          userMenu.classList.remove('show');
          userMenu.setAttribute('aria-hidden', 'true');
          userBtn.setAttribute('aria-expanded', 'false');
        }
      });
    })();
  </script>
</body>
</html>
